{
    "name": "guaita/guaita",
    "description": "CLI tool to monitor URL content changes",
    "type": "project",
    "require": {
        "symfony/console": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/dom-crawler": "^8.0",
        "jfcherng/php-diff": "^6.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "bin": ["guaita"],
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    }
}
